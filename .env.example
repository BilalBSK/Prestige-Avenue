DATABASE_URL="postgresql://postgres:postgres@localhost:5432/prestige_avenue?schema=public"
NEXTAUTH_SECRET="replace-with-strong-secret"
NEXTAUTH_URL="http://localhost:3000"

# Cloudflare R2 (stockage images voitures — S3-compatible, egress gratuit)
# 1. Créer un bucket sur dash.cloudflare.com > R2
# 2. Activer l'accès public (r2.dev subdomain ou domaine custom)
# 3. Créer un token API avec permission "Object Read & Write" sur le bucket
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET="prestige-avenue-media"
R2_PUBLIC_BASE_URL="https://pub-xxxxxxxx.r2.dev"
